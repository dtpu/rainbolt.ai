GOOGLE_API_KEY=your_google_api_key_here
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=htv2025
MAPILLARY_API_KEY=your_mapillary_api_key

# Security gate
# Comma-separated list of browser origins allowed to open the WebSocket and call
# the mapillary endpoint. Set to your real frontend origin(s) in production.
ALLOWED_ORIGINS=http://localhost:3000
# Shared secret for the server-to-server upload proxy. The Next.js /api/upload
# route sends this header; the backend rejects /upload-image without it.
# Must match the root .env BACKEND_INTERNAL_KEY.
BACKEND_INTERNAL_KEY=
# Set to 1 to expose the Swagger / OpenAPI docs. Leave off (0 or unset) in prod.
ENABLE_DOCS=0

# Only needed to run ingest.py (rebuilding the index from the Kaggle dataset).
# Get a token at kaggle.com -> Settings -> API -> Create New Token.
# New-style tokens (KGAT_...) use a single variable:
KAGGLE_API_TOKEN=
# (older kaggle.json style also works: KAGGLE_USERNAME + KAGGLE_KEY)